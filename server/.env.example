# Core API
PORT=4000
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-oss-20b
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=qa-with-yt-video

# Vector + DB
PGVECTOR_CONNECTION_STRING=postgresql://user:password@host:5432/dbname?sslmode=verify-full
PGVECTOR_TABLE=qa_video_embeddings
PGVECTOR_COLLECTION_TABLE=qa_video_collections
PGVECTOR_COLLECTION=default_video_collection

# Bright Data
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_NOTIFY_URL=http://localhost:4000/webhook
SERVER_PUBLIC_URL=http://localhost:4000

# Optional ingestion persistence overrides
WEBHOOK_DB_CONNECTION_STRING=
INGESTION_TABLE=qa_video_ingestions
